# Local development examples only. Replace every value outside local development.
DATABASE_URL=mysql+asyncmy://purchasing_agent:local-dev-only@127.0.0.1:3306/purchasing_agent?charset=utf8mb4
TEST_DATABASE_URL=mysql+asyncmy://purchasing_agent_test:local-test-only@127.0.0.1:3307/purchasing_agent_test?charset=utf8mb4

# Optional Agent chat runtime. Never commit real keys.
AGENT_ENABLED=false
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-3-5-sonnet-20241022
AGENT_API_KEY=replace-locally
AGENT_BASE_URL=
AGENT_TIMEOUT_SECONDS=15
AGENT_MAX_RETRIES=1
AGENT_REDIS_URL=redis://127.0.0.1:6379/0
AGENT_SESSION_TTL_SECONDS=604800
AGENT_ALLOW_IN_MEMORY=false
